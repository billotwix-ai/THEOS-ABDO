[Unit]
Description=Theos Compiler Bot — © smartpepole
After=network.target

[Service]
Type=simple
User=smartpepole
WorkingDirectory=/home/smartpepole/theos-bot
ExecStart=/usr/bin/python3 /home/smartpepole/theos-bot/bot.py
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
